<Application x:Class="MTGB.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="UI/TrayContextMenu.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── MTGB semantic colours ─────────────────────── -->
            <Color x:Key="MtgbPrimaryColor">#2D7DD2</Color>
            <Color x:Key="MtgbSuccessColor">#3BB273</Color>
            <Color x:Key="MtgbWarningColor">#F18F01</Color>
            <Color x:Key="MtgbErrorColor">#E84855</Color>
            <Color x:Key="MtgbOfflineColor">#888780</Color>

            <SolidColorBrush x:Key="MtgbPrimary"
                             Color="{StaticResource MtgbPrimaryColor}"/>
            <SolidColorBrush x:Key="MtgbSuccess"
                             Color="{StaticResource MtgbSuccessColor}"/>
            <SolidColorBrush x:Key="MtgbWarning"
                             Color="{StaticResource MtgbWarningColor}"/>
            <SolidColorBrush x:Key="MtgbError"
                             Color="{StaticResource MtgbErrorColor}"/>
            <SolidColorBrush x:Key="MtgbOffline"
                             Color="{StaticResource MtgbOfflineColor}"/>

            <!-- ── MTGB Art Deco dark palette ────────────────── -->
            <Color x:Key="BgDeepColor">#0D0D0F</Color>
            <Color x:Key="BgRaisedColor">#141417</Color>
            <Color x:Key="BgCardColor">#1A1A1F</Color>
            <Color x:Key="BgHoverColor">#22222A</Color>
            <Color x:Key="BrassColor">#C9930E</Color>
            <Color x:Key="BrassDimColor">#8B6508</Color>
            <Color x:Key="GoldTextColor">#F0C840</Color>
            <Color x:Key="TextPrimaryColor">#F0EDE8</Color>
            <Color x:Key="TextSecondaryColor">#C8C0B8</Color>
            <Color x:Key="TextDimColor">#8A8078</Color>

            <SolidColorBrush x:Key="BgDeepBrush"
                             Color="{StaticResource BgDeepColor}"/>
            <SolidColorBrush x:Key="BgRaisedBrush"
                             Color="{StaticResource BgRaisedColor}"/>
            <SolidColorBrush x:Key="BgCardBrush"
                             Color="{StaticResource BgCardColor}"/>
            <SolidColorBrush x:Key="BgHoverBrush"
                             Color="{StaticResource BgHoverColor}"/>
            <SolidColorBrush x:Key="BrassBrush"
                             Color="{StaticResource BrassColor}"/>
            <SolidColorBrush x:Key="BrassDimBrush"
                             Color="{StaticResource BrassDimColor}"/>
            <SolidColorBrush x:Key="GoldTextBrush"
                             Color="{StaticResource GoldTextColor}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"
                             Color="{StaticResource TextPrimaryColor}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"
                             Color="{StaticResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="TextDimBrush"
                             Color="{StaticResource TextDimColor}"/>

            <!-- ── Force dark system colours throughout MTGB ─── -->
            <SolidColorBrush
                x:Key="{x:Static SystemColors.ControlBrushKey}"
                Color="#141417"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.ControlTextBrushKey}"
                Color="#F0EDE8"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.WindowBrushKey}"
                Color="#0D0D0F"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.WindowTextBrushKey}"
                Color="#F0EDE8"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.HighlightBrushKey}"
                Color="#22222A"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                Color="#F0C840"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.MenuBrushKey}"
                Color="#141417"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.MenuTextBrushKey}"
                Color="#F0EDE8"/>
            <SolidColorBrush
                x:Key="{x:Static SystemColors.MenuHighlightBrushKey}"
                Color="#22222A"/>

            <!-- ── Base styles — dark throughout ─────────────── -->
            <Style TargetType="Window">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="13"/>
                <Setter Property="Background"
                        Value="{StaticResource BgRaisedBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="13"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style TargetType="Button">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="13"/>
                <Setter Property="Padding"
                        Value="16 6"/>
                <Setter Property="BorderThickness"
                        Value="1"/>
                <Setter Property="Cursor"
                        Value="Hand"/>
                <Setter Property="Background"
                        Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BrassDimBrush}"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="12"/>
                <Setter Property="Background"
                        Value="{StaticResource BgDeepBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BrassDimBrush}"/>
                <Setter Property="CaretBrush"
                        Value="{StaticResource BrassBrush}"/>
                <Setter Property="Padding"
                        Value="8 6"/>
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="12"/>
                <Setter Property="Background"
                        Value="{StaticResource BgDeepBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BrassDimBrush}"/>
                <Setter Property="CaretBrush"
                        Value="{StaticResource BrassBrush}"/>
                <Setter Property="Padding"
                        Value="8 6"/>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="12"/>
                <Setter Property="Background"
                        Value="{StaticResource BgDeepBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BrassDimBrush}"/>
                <Setter Property="Padding"
                        Value="8 6"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="12"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style TargetType="Label">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="12"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style TargetType="TabControl">
                <Setter Property="Background"
                        Value="{StaticResource BgRaisedBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BrassDimBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style TargetType="TabItem">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"
                        Value="12"/>
                <Setter Property="Background"
                        Value="{StaticResource BgDeepBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BrassDimBrush}"/>
                <Setter Property="Padding"
                        Value="16 8"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background"
                                Value="{StaticResource BgRaisedBrush}"/>
                        <Setter Property="Foreground"
                                Value="{StaticResource GoldTextBrush}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground"
                                Value="{StaticResource TextPrimaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Background"
                        Value="{StaticResource BgDeepBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource BrassDimBrush}"/>
            </Style>

            <Style TargetType="ToolTip">
                <Setter Property="Background"
                        Value="{StaticResource BgDeepBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource GoldTextBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BrassDimBrush}"/>
                <Setter Property="BorderThickness"
                        Value="1"/>
                <Setter Property="FontFamily"
                        Value="Courier New"/>
                <Setter Property="FontSize"
                        Value="11"/>
                <Setter Property="FontStyle"
                        Value="Italic"/>
                <Setter Property="Padding"
                        Value="10 6"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>