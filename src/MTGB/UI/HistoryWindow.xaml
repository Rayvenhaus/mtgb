<Window x:Class="MTGB.UI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MTGB — Notification History"
        Width="700" Height="580"
        MinWidth="700" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        BorderBrush="{StaticResource AccentBlueBrush}"
        BorderThickness="2"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Icon="/Assets/MTGB_32.png">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/mtgbTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Filter button ──────────────────────────────── -->
            <Style x:Key="FilterButton" TargetType="Button">
                <Setter Property="Background"
                        Value="{StaticResource BgRaisedBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextMutedBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BorderBlueBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding"    Value="14,6"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background"
                                            Value="{StaticResource BgDeepestBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource GoldPrimaryBrush}"/>
                                    <Setter Property="BorderBrush"
                                            Value="{StaticResource AccentBlueBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Filter button active ───────────────────────── -->
            <Style x:Key="FilterButtonActive" TargetType="Button"
                   BasedOn="{StaticResource FilterButton}">
                <Setter Property="Background"
                        Value="{StaticResource BgDeepestBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource GoldPrimaryBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource AccentBlueBrush}"/>
            </Style>

            <!-- ── Clear button ───────────────────────────────── -->
            <Style x:Key="ClearButton" TargetType="Button"
                   BasedOn="{StaticResource FilterButton}">
                <Setter Property="Foreground"
                        Value="{StaticResource SemanticErrorBrush}"/>
                <Setter Property="BorderBrush" Value="#38E84855"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ──────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgDeepestBrush}"
                BorderBrush="{StaticResource BorderBlueBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10"
                             Fill="{StaticResource SemanticSuccessBrush}"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="MTGB — The Monitor That Goes Bing"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource GoldPrimaryBrush}"/>
                        <TextBlock Text="NOTIFICATION HISTORY"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="10"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- View toggle -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Button x:Name="ViewHistoryButton"
                            Content="History"
                            Style="{StaticResource FilterButtonActive}"
                            Margin="0,0,4,0"
                            Click="OnViewHistoryClick"/>
                    <Button x:Name="ViewStatsButton"
                            Content="Stats"
                            Style="{StaticResource FilterButton}"
                            Click="OnViewStatsClick"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="✕"
                        Style="{StaticResource FilterButton}"
                        Width="32" Height="32"
                        Padding="0" FontSize="14"
                        Click="OnCloseClick"/>
            </Grid>
        </Border>

        <!-- ── Filter bar ─────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BgDeepestBrush}"
                BorderBrush="{StaticResource BorderBlueBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <TextBlock Text="FILTER:"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <Button x:Name="FilterAll"
                            Content="All"
                            Style="{StaticResource FilterButtonActive}"
                            Margin="0,0,4,0"
                            Click="OnFilterAllClick"/>
                    <Button x:Name="FilterJobs"
                            Content="Print jobs"
                            Style="{StaticResource FilterButton}"
                            Margin="0,0,4,0"
                            Click="OnFilterJobsClick"/>
                    <Button x:Name="FilterPrinter"
                            Content="Printer"
                            Style="{StaticResource FilterButton}"
                            Margin="0,0,4,0"
                            Click="OnFilterPrinterClick"/>
                    <Button x:Name="FilterAlerts"
                            Content="Alerts"
                            Style="{StaticResource FilterButton}"
                            Margin="0,0,4,0"
                            Click="OnFilterAlertsClick"/>
                    <Button x:Name="FilterSuppressed"
                            Content="Suppressed"
                            Style="{StaticResource FilterButton}"
                            Margin="0,0,12,0"
                            Click="OnFilterSuppressedClick"/>

                    <ComboBox x:Name="PrinterFilter"
                              Width="140"
                              VerticalAlignment="Center"
                              SelectionChanged="OnPrinterFilterChanged">
                        <ComboBoxItem Content="All printers" IsSelected="True"/>
                    </ComboBox>
                </WrapPanel>

                <Button Grid.Column="1"
                        Content="Clear history"
                        Style="{StaticResource ClearButton}"
                        VerticalAlignment="Center"
                        Click="OnClearHistoryClick"/>
            </Grid>
        </Border>

        <!-- ── Content area ───────────────────────────────────── -->
        <Grid Grid.Row="2" Background="{StaticResource BgPrimaryBrush}">
            <ScrollViewer x:Name="HistoryView"
                          VerticalScrollBarVisibility="Auto"
                          Padding="12,8">
                <StackPanel x:Name="HistoryPanel"/>
            </ScrollViewer>

            <ScrollViewer x:Name="StatsView"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,16">
                <StackPanel x:Name="StatsPanel"/>
            </ScrollViewer>
        </Grid>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource BgDeepestBrush}"
                BorderBrush="{StaticResource BorderBlueBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FooterCountText"
                           Grid.Column="0"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           FontSize="12" FontStyle="Italic"
                           Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Close"
                        Style="{StaticResource FilterButton}"
                        Click="OnCloseClick"/>
            </Grid>
        </Border>

    </Grid>
</Window>