<Window x:Class="MTGB.UI.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MTGB — Update Available"
        Width="560" Height="480"
        MinWidth="560" MinHeight="480"
        MaxWidth="560" MaxHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/mtgbTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource BgDeepestBrush}"
            BorderBrush="{StaticResource AccentBlueBrush}"
            BorderThickness="2"
            CornerRadius="14">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ──────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgDeepestBrush}"
                    BorderBrush="{StaticResource BorderBlueBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0"
                    Padding="24,16"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel>
                    <TextBlock Text="MTGB UPDATE"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBlueBrush}"/>
                    <TextBlock x:Name="VersionHeader"
                               Text="Version 0.0.0 is available"
                               FontFamily="Georgia, Times New Roman"
                               FontSize="20" FontStyle="Italic"
                               Foreground="{StaticResource GoldPrimaryBrush}"
                               Margin="0,6,0,0"/>
                    <TextBlock x:Name="CurrentVersionText"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="11"
                               Foreground="{StaticResource TextDimBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Release notes ──────────────────────────────── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,20"
                          Background="{StaticResource BgPrimaryBrush}">
                <StackPanel>
                    <TextBlock Text="WHAT'S NEW"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource GoldPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="ReleaseNotesText"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ── Progress bar ───────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgPrimaryBrush}"
                    Padding="24,0,24,16">
                <StackPanel x:Name="ProgressPanel"
                            Visibility="Collapsed">
                    <TextBlock x:Name="ProgressText"
                               Text="Downloading..."
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="12"
                               Foreground="{StaticResource TextDimBrush}"
                               Margin="0,0,0,8"/>
                    <Border Background="{StaticResource BgRaisedBrush}"
                            BorderBrush="{StaticResource BorderBlueBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="8">
                        <Border x:Name="ProgressFill"
                                Background="{StaticResource AccentBlueBrush}"
                                CornerRadius="6"
                                HorizontalAlignment="Left"
                                Width="0"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Navigation ─────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="{StaticResource BgDeepestBrush}"
                    BorderBrush="{StaticResource BorderBlueBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,14,14"
                    Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="12" FontStyle="Italic"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center"
                               Text="The Ministry recommends updating."/>

                    <Button x:Name="CancelButton"
                            Grid.Column="1"
                            Content="Later"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnCancelClick"/>

                    <Button x:Name="InstallButton"
                            Grid.Column="3"
                            Content="OK to Install"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Click="OnInstallClick"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>