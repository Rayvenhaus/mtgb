                                                   Style="{StaticResource SettingSubLabel}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Clear history"
                                            Style="{StaticResource DangerButton}"
                                            VerticalAlignment="Center"
                                            Click="OnClearHistoryClick"/>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- Diagnostic mode -->
                        <StackPanel x:Name="DiagnosticPanel"
                                    Visibility="Collapsed"
                                    Margin="0,10,0,0">
                            <TextBlock Text="Diagnostic mode"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       Margin="2,8,0,6"/>
                            <Border Style="{StaticResource SectionCard}"
                                    BorderBrush="{StaticResource BorderBlueBrush}">
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Dump API responses"
                                                       Style="{StaticResource SettingLabel}"
                                                       Foreground="{StaticResource AccentBlueBrush}"/>
                                            <TextBlock Text="Writes raw JSON from all endpoints to %APPDATA%\MTGB\."
                                                       Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Dump API"
                                                Style="{StaticResource GhostButton}"
                                                VerticalAlignment="Center"
                                                Click="OnDumpApiClick"/>
                                    </Grid>
                                </Border>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════ -->
            <!-- TAB 6: PRIVACY                                  -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="Privacy">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Privacy" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="The Ministry is transparent about what it knows. Which is very little. By design."
                                   Style="{StaticResource SectionSubTitle}"/>

                        <!-- Telemetry -->
                        <TextBlock Text="Anonymous telemetry" Style="{StaticResource GroupLabel}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Allow anonymous telemetry"
                                                       Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Version, printer types, event counts. No names. No IDs. The scribes are discreet."
                                                       Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="TelemetryEnabledToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center"
                                                      Click="OnTelemetryToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <StackPanel>
                                        <TextBlock Text="What the scribes record"
                                                   Style="{StaticResource SettingLabel}"/>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="✓  MTGB version &amp; Windows version"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="✓  Printer count &amp; integration type"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="✓  Which event types are enabled"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="✓  Poll &amp; toast success/failure counts"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="✓  A random anonymous install ID"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Text="✗  No API keys, org IDs or credentials"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="✗  No printer names or job filenames"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="✗  No IP addresses or anything identifying"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="12" Foreground="{StaticResource TextDimBrush}"/>
                                        </StackPanel>
                                        <Button Content="Full transparency policy ↗"
                                                Style="{StaticResource GhostButton}"
                                                HorizontalAlignment="Left"
                                                Margin="0,12,0,0"
                                                Click="OnTelemetryPolicyClick"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Community map -->
                        <TextBlock Text="Community map" Style="{StaticResource GroupLabel}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Registration status"
                                                       Style="{StaticResource SettingLabel}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse x:Name="MapStatusDot"
                                                         Width="8" Height="8"
                                                         Fill="{StaticResource TextDimBrush}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0"/>
                                                <TextBlock x:Name="MapStatusText"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextDimBrush}"
                                                           Text="Checking..."
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button x:Name="MapRefreshButton"
                                                Grid.Column="1"
                                                Content="Refresh"
                                                Style="{StaticResource GhostButton}"
                                                VerticalAlignment="Center"
                                                Click="OnMapStatusRefreshClick"/>
                                    </Grid>
                                </Border>

                                <!-- Opt out -->
                                <Border x:Name="MapOptOutPanel"
                                        Style="{StaticResource SettingRow}"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Remove my dot"
                                                       Style="{StaticResource SettingLabel}"
                                                       Foreground="{StaticResource SemanticErrorBrush}"/>
                                            <TextBlock Text="The Ministry will file the departure form without complaint."
                                                       Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <Button x:Name="MapOptOutButton"
                                                Grid.Column="1"
                                                Content="Opt out"
                                                Style="{StaticResource DangerButton}"
                                                VerticalAlignment="Center"
                                                Click="OnMapOptOutClick"/>
                                    </Grid>
                                </Border>

                                <!-- Opt in -->
                                <Border x:Name="MapOptInPanel"
                                        Style="{StaticResource SettingRow}"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Add me to the map"
                                                   Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="State or territory level only. The dots are anonymous."
                                                   Style="{StaticResource SettingSubLabel}"/>

                                        <TextBlock Text="COUNTRY"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource GoldPrimaryBrush}"
                                                   Margin="0,14,0,6"/>
                                        <ComboBox x:Name="PrivacyCountrySelector"
                                                  Margin="0,0,0,12"
                                                  SelectionChanged="OnPrivacyCountryChanged"/>

                                        <StackPanel x:Name="PrivacyStateSelectorPanel"
                                                    Visibility="Collapsed"
                                                    Margin="0,0,0,12">
                                            <TextBlock Text="STATE / TERRITORY"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource GoldPrimaryBrush}"
                                                       Margin="0,0,0,6"/>
                                            <ComboBox x:Name="PrivacyStateSelector"
                                                      SelectionChanged="OnPrivacyStateChanged"/>
                                        </StackPanel>

                                        <Border Background="{StaticResource BgDeepestBrush}"
                                                BorderBrush="{StaticResource BorderBlueBrush}"
                                                BorderThickness="1" CornerRadius="7"
                                                Padding="12,10" Margin="0,0,0,12">
                                            <TextBlock x:Name="PrivacyConfirmText"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       FontSize="13"
                                                       Foreground="{StaticResource GoldPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <Button x:Name="MapOptInButton"
                                                Content="Add me to the map"
                                                Style="{StaticResource PrimaryButton}"
                                                HorizontalAlignment="Left"
                                                Click="OnMapOptInClick"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI"
                                               FontSize="12"
                                               Foreground="{StaticResource TextDimBrush}"
                                               FontStyle="Italic" TextWrapping="Wrap">
                                        State or territory level only. No city. No street. No postcode.
                                        The map is real. The dots are anonymous.
                                        There is nothing to see here. Except tiny little unassuming dots.
