            <!-- ══════════════════════════════════════════════ -->
            <!-- TAB 4: QUIET HOURS                              -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="Quiet hours">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Quiet hours" Style="{StaticResource SectionTitle}"/>
