                                                Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="GitHub ↗"
                                                Style="{StaticResource GhostButton}"
                                                VerticalAlignment="Center"
                                                Click="OnGitHubClick"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingRow}"
                                        BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock
                                                Text="The full origin story"
                                                Style="{StaticResource SettingLabel}"/>
                                            <TextBlock
                                                Text="As filed with the Redundant Department of Redundancy."
                                                Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Read ↗"
                                                Style="{StaticResource GhostButton}"
                                                VerticalAlignment="Center"
                                                Click="OnOriginStoryClick"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </Border>

                        <TextBlock
                            Text="Inspired by Monty Python's &quot;The Machine That Goes Ping&quot;. No NHS budget was harmed in the making of this app, although the Redundant Department of Redundancy was notified, twice, in triplicate."
                            FontFamily="Courier New"
                            FontSize="9"
                            Foreground="{StaticResource TextDimBrush}"
                            FontStyle="Italic"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            Margin="20 10 20 4"/>

                        <TextBlock
                            Text="Philosophically indebted to Sir Terry Pratchett."
                            FontFamily="Courier New"
                            FontSize="9"
                            Foreground="{StaticResource TextDimBrush}"
                            FontStyle="Italic"
                            HorizontalAlignment="Center"
                            Margin="0 2 0 20"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Footer ────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgDeepBrush}"
                BorderBrush="#38C9930E"
                BorderThickness="0 1 0 0"
                Padding="20 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FooterStatusText"
                           Grid.Column="0"
                           Text="Not connected — enter credentials above"
                           FontFamily="Courier New"
                           FontSize="10"
                           Foreground="{StaticResource TextDimBrush}"
                           FontStyle="Italic"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Save"
                            Style="{StaticResource BrassButton}"
                            Margin="0 0 8 0"
                            Click="OnSaveClick"/>
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Style="{StaticResource GhostButton}"
                            IsEnabled="False"
                            Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>