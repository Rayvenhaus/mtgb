                                </Border>
                                <Border x:Name="QuietHoursEndPanel"
                                        Style="{StaticResource SettingRow}"
                                        IsEnabled="False" Opacity="0.5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="End time" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="When the Ministry reopens, reluctantly." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <TextBox x:Name="QuietEndInput"
                                                 Grid.Column="1"
                                                 Style="{StaticResource MtgbInput}"
                                                 Text="08:00" Width="80"
                                                 TextAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 TextChanged="OnQuietHoursChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Allow critical alerts" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Printer offline and failures still Bing. Even at 3am." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="AllowCriticalToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Click="OnAllowCriticalChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════ -->
            <!-- TAB 5: ADVANCED                                 -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Advanced" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Here be dragons. And polling intervals. Mostly polling intervals."
                                   Style="{StaticResource SectionSubTitle}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Polling interval (seconds)" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="How often MTGB checks in. Minimum 10s. Be a good API citizen." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <TextBox x:Name="PollingIntervalInput"
                                                 Grid.Column="1"
                                                 Style="{StaticResource MtgbInput}"
                                                 Text="30" Width="60"
                                                 TextAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 TextChanged="OnPollingIntervalChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Webhook receiver" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Real-time events via local HTTP listener. Requires public URL or LAN." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="WebhookToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center"
                                                      Click="OnWebhookToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="WebhookPortPanel"
                                        Style="{StaticResource SettingRow}"
                                        IsEnabled="False" Opacity="0.5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Webhook port" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Local port for incoming SimplyPrint webhook POSTs." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <TextBox x:Name="WebhookPortInput"
                                                 Grid.Column="1"
                                                 Style="{StaticResource MtgbInput}"
                                                 Text="7878" Width="70"
                                                 TextAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 TextChanged="OnWebhookPortChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Start with Windows" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Boot MTGB on login. Recommended. The Ministry approves." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="StartupToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Click="OnStartupToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Language" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Interface language. More coming via community translations." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="LanguageSelector"
                                                  Grid.Column="1"
                                                  Width="120" VerticalAlignment="Center"
                                                  SelectionChanged="OnLanguageChanged">
                                            <ComboBoxItem Content="English (AU)" Tag="en-AU" IsSelected="True"/>
                                            <ComboBoxItem Content="English (GB)" Tag="en-GB"/>
                                            <ComboBoxItem Content="English (US)" Tag="en-US"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Danger zone -->
                        <TextBlock Text="Danger zone"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource SemanticErrorBrush}"
                                   Margin="2,8,0,6"/>
                        <Border Style="{StaticResource SectionCard}"
                                BorderBrush="#38E84855">
                            <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Clear notification history"
                                                   Style="{StaticResource SettingLabel}"
                                                   Foreground="{StaticResource SemanticErrorBrush}"/>
