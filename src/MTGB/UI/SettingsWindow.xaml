                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Bed temp dropped" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Bed temperature dropping. Tuck it in. Put the kettle on." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventBedTemp" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="False"
                                                      Tag="temp.bed.low" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Print queue" Style="{StaticResource GroupLabel}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Item added to queue" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Someone has added to the pile." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventQueueAdded" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="False"
                                                      Tag="queue.added" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Queue emptied" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="The queue is empty. The Ministry is at peace." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventQueueEmptied" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="False"
                                                      Tag="queue.emptied" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
