                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════ -->
            <!-- TAB 7: ABOUT                                    -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="0,10,0,20">
                            <Border Width="64" Height="64"
                                    Background="{StaticResource BgRaisedBrush}"
                                    BorderBrush="{StaticResource AccentBlueBrush}"
