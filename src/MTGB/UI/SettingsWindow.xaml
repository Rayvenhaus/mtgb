<Window x:Class="MTGB.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MTGB — Settings"
        Width="740" Height="680"
        MinWidth="740" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        BorderBrush="{StaticResource AccentBlueBrush}"
        BorderThickness="2"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Icon="/Assets/MTGB_32.png"
        Topmost="True" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/mtgbTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Section card ───────────────────────────────── -->
            <Style x:Key="SectionCard" TargetType="Border">
                <Setter Property="Background"
                        Value="{StaticResource BgRaisedBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BorderBlueBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"     Value="10"/>
                <Setter Property="Margin"           Value="0,0,0,12"/>
                <Setter Property="ClipToBounds"     Value="True"/>
            </Style>

            <!-- ── Setting row ────────────────────────────────── -->
            <Style x:Key="SettingRow" TargetType="Border">
                <Setter Property="Padding"         Value="16,12"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BorderBlueBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Style>

            <!-- ── Setting label ──────────────────────────────── -->
            <Style x:Key="SettingLabel" TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <!-- ── Setting sublabel ───────────────────────────── -->
            <Style x:Key="SettingSubLabel" TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextDimBrush}"/>
                <Setter Property="FontStyle"  Value="Italic"/>
                <Setter Property="Margin"     Value="0,4,0,0"/>
            </Style>

            <!-- ── Section title ──────────────────────────────── -->
            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"   Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Margin"     Value="0,0,0,4"/>
            </Style>

            <!-- ── Section subtitle ───────────────────────────── -->
            <Style x:Key="SectionSubTitle" TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextDimBrush}"/>
                <Setter Property="FontStyle"  Value="Italic"/>
                <Setter Property="Margin"     Value="0,0,0,16"/>
            </Style>

            <!-- ── Group label ────────────────────────────────── -->
            <Style x:Key="GroupLabel" TargetType="TextBlock">
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"   Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground"
                        Value="{StaticResource AccentBlueBrush}"/>
                <Setter Property="Margin"     Value="2,8,0,6"/>
            </Style>

            <!-- ── Status badges ──────────────────────────────── -->
            <Style x:Key="BadgeBlue" TargetType="Border">
                <Setter Property="Background"
                        Value="{StaticResource BgRaisedBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BorderBlueBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="4"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>

            <Style x:Key="BadgeGreen" TargetType="Border">
                <Setter Property="Background"  Value="#203BB273"/>
                <Setter Property="BorderBrush" Value="#593BB273"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="4"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>

            <Style x:Key="BadgeRed" TargetType="Border">
                <Setter Property="Background"  Value="#20E84855"/>
                <Setter Property="BorderBrush" Value="#59E84855"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="4"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ─────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgDeepestBrush}"
                BorderBrush="{StaticResource BorderBlueBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="HeaderBingDot"
                             Width="10" Height="10"
                             Fill="{StaticResource SemanticSuccessBrush}"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="MTGB — The Monitor That Goes Bing"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource GoldPrimaryBrush}"/>
                        <TextBlock Text="SETTINGS"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="10"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕"
                        Style="{StaticResource GhostButton}"
                        Width="32" Height="32"
                        Padding="0" FontSize="14"
                        Click="OnCloseClick"/>
            </Grid>
        </Border>

        <!-- ── Tab control ───────────────────────────────────── -->
        <TabControl Grid.Row="1"
                    x:Name="MainTabs"
                    Background="{StaticResource BgPrimaryBrush}"
                    BorderThickness="0"
                    SelectionChanged="OnTabChanged">

            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource BgDeepestBrush}"
                                BorderBrush="{StaticResource BorderBlueBrush}"
                                BorderThickness="0,0,0,1">
                            <TabPanel IsItemsHost="True" Margin="12,0,0,0"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="{StaticResource BgPrimaryBrush}"
                                ClipToBounds="True">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="FontFamily"
                            Value="Segoe UI Variable, Segoe UI"/>
                    <Setter Property="FontSize"        Value="13"/>
                    <Setter Property="Padding"         Value="16,11"/>
                    <Setter Property="Foreground"
                            Value="{StaticResource TextMutedBrush}"/>
                    <Setter Property="Background"      Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor"          Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder"
                                        Background="Transparent"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock x:Name="TabText"
                                               Text="{TemplateBinding Header}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder"
                                                Property="BorderBrush"
                                                Value="{StaticResource GoldPrimaryBrush}"/>
                                        <Setter TargetName="TabText"
                                                Property="Foreground"
                                                Value="{StaticResource GoldPrimaryBrush}"/>
                                        <Setter TargetName="TabBorder"
                                                Property="Background"
                                                Value="Transparent"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabText"
                                                Property="Foreground"
                                                Value="{StaticResource TextPrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- ══════════════════════════════════════════════ -->
            <!-- TAB 1: ACCOUNT                                  -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="Account">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Account" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Connect MTGB to SimplyPrint. It won't bite. Probably."
                                   Style="{StaticResource SectionSubTitle}"/>

                        <!-- Auth mode -->
                        <Border Style="{StaticResource SectionCard}">
                            <Border Style="{StaticResource SettingRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Authentication mode"
                                                   Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="API key is simpler. OAuth2 is fancier."
                                                   Style="{StaticResource SettingSubLabel}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                        <RadioButton x:Name="RadioApiKey"
                                                     Content="API Key"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     FontFamily="Segoe UI Variable, Segoe UI"
                                                     FontSize="13"
                                                     Margin="0,0,16,0"
                                                     IsChecked="True"
                                                     Checked="OnAuthModeChanged"/>
                                        <RadioButton x:Name="RadioOAuth"
                                                     Content="OAuth2"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     FontFamily="Segoe UI Variable, Segoe UI"
                                                     FontSize="13"
                                                     Checked="OnAuthModeChanged"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- API Key panel -->
                        <Border x:Name="ApiKeyPanel" Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <StackPanel>
                                        <TextBlock Text="Organisation ID"
                                                   Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="Found in your SimplyPrint API base URL — simplyprint.io/api/{id}/"
                                                   Style="{StaticResource SettingSubLabel}"/>
                                        <TextBox x:Name="OrgIdInput"
                                                 Style="{StaticResource MtgbInput}"
                                                 Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <StackPanel>
                                        <TextBlock Text="API Key"
                                                   Style="{StaticResource SettingLabel}"/>
                                        <TextBlock Text="Stored securely via Windows Credential Manager. Never written to disk."
                                                   Style="{StaticResource SettingSubLabel}"/>
                                        <PasswordBox x:Name="ApiKeyInput"
                                                     Style="{StaticResource MtgbPasswordInput}"
                                                     Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- OAuth2 panel -->
                        <Border x:Name="OAuthPanel"
                                Style="{StaticResource SectionCard}"
                                Visibility="Collapsed">
                            <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                <StackPanel>
                                    <TextBlock Text="SimplyPrint OAuth2"
                                               Style="{StaticResource SettingLabel}"/>
                                    <TextBlock Text="Opens your browser. You log in. We get a token. Nobody sees your password."
                                               Style="{StaticResource SettingSubLabel}"/>
                                    <Button x:Name="OAuthLoginButton"
                                            Content="Login with SimplyPrint ↗"
                                            Style="{StaticResource GhostButton}"
                                            HorizontalAlignment="Left"
                                            Margin="0,10,0,0"
                                            Click="OnOAuthLoginClick"/>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Connection status -->
                        <Border x:Name="ConnectionStatusPanel"
                                Background="{StaticResource BgRaisedBrush}"
                                BorderBrush="{StaticResource BorderBlueBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Margin="0,0,0,0" Visibility="Collapsed">
                            <Border Padding="14,12" BorderThickness="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="ConnectionDot"
                                             Width="8" Height="8"
                                             Fill="{StaticResource SemanticSuccessBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                                    <TextBlock x:Name="ConnectionStatusText"
                                               Grid.Column="1"
                                               Text="Connected"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               FontSize="13"
                                               Foreground="{StaticResource SemanticSuccessBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- Connect / Disconnect -->
                        <StackPanel x:Name="ConnectButtonPanel"
                                    Orientation="Horizontal"
                                    Margin="0,10,0,0" Height="36">
                            <Button x:Name="ConnectButton"
                                    Content="Connect to SimplyPrint"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,0"
                                    Click="OnConnectClick"/>
                            <Button x:Name="DisconnectButton"
                                    Content="Disconnect"
                                    Style="{StaticResource GhostButton}"
                                    Visibility="Collapsed"
                                    Click="OnDisconnectClick"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════ -->
            <!-- TAB 2: PRINTERS                                 -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="Printers">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Printers" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Your farm. All of it. Even the ones misbehaving."
                                   Style="{StaticResource SectionSubTitle}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel x:Name="PrinterListPanel">
                                <Border Style="{StaticResource SettingRow}"
                                        BorderThickness="0" Padding="14,20">
                                    <TextBlock x:Name="NoPrintersText"
                                               Text="No printers found. Connect your account first."
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               FontSize="13"
                                               Foreground="{StaticResource TextDimBrush}"
                                               FontStyle="Italic"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Button Content="Refresh printer list"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Left"
                                Click="OnRefreshPrintersClick"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════════════════════ -->
            <!-- TAB 3: NOTIFICATIONS                            -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="Notifications">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Notifications" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Choose your Bings. All of them, some of them, or none. We don't judge."
                                   Style="{StaticResource SectionSubTitle}"/>

                        <!-- General -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Global mute"
                                                       Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Blessed silence. Overrides everything."
                                                       Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="GlobalMuteToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center"
                                                      Click="OnGlobalMuteChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Action buttons on toasts"
                                                       Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Pause and Cancel from the notification itself."
                                                       Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="ActionButtonsToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center"
                                                      IsChecked="True"
                                                      Click="OnActionButtonsChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Notification grouping"
                                                       Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Batch events within a 5 second window."
                                                       Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="GroupingToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center"
                                                      IsChecked="True"
                                                      Click="OnGroupingChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Sound"
                                                       Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="It goes Bing. Audibly."
                                                       Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="SoundToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center"
                                                      IsChecked="True"
                                                      Click="OnSoundChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Print jobs" Style="{StaticResource GroupLabel}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print started" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="It has begun. Try not to watch it too closely." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventJobStarted" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Tag="job.started" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print finished" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="And there was much rejoicing." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventJobFinished" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Tag="job.finished" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print failed" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Spaghetti may be involved." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventJobFailed" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Tag="job.failed" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print paused" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Taking five. The print, not you. Although, same." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventJobPaused" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Tag="job.paused" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print cancelled" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="The Redundant Department has been notified." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventJobCancelled" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Tag="job.cancelled" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print resumed" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="And so it continues." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventJobResumed" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="False"
                                                      Tag="job.resumed" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Printer" Style="{StaticResource GroupLabel}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Printer offline" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="It has gone to a better place. Possibly the shed." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventPrinterOffline" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      Tag="printer.offline" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Printer back online" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="It has returned. No explanation given." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventPrinterOnline" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="False"
                                                      Tag="printer.online" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Progress milestones" Style="{StaticResource GroupLabel}"/>
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print at 25%" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="One quarter done. Three quarters of the anxiety remains." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventProgress25" Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center" IsChecked="False"
                                                      Tag="progress.25" Click="OnEventToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Print at 50%" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="Halfway. Either going brilliantly or you haven't looked yet." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="EventProgress50" Grid.Column="1"
