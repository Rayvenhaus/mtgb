                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Enable quiet hours" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="No Bings during the specified window." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="QuietHoursToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource MtgbToggle}"
                                                      VerticalAlignment="Center"
                                                      Click="OnQuietHoursToggleChanged"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="QuietHoursTimePanel"
                                        Style="{StaticResource SettingRow}"
                                        IsEnabled="False" Opacity="0.5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Start time" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="When the Ministry closes for the evening." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <TextBox x:Name="QuietStartInput"
