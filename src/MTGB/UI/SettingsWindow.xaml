                                         Width="22" Height="22"
                                         Fill="{StaticResource SemanticSuccessBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="MTGB"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource GoldPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="VersionText"
                                       Text="The Monitor That Goes Bing · v0.5.2"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="12"
                                       Foreground="{StaticResource TextDimBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Background="{StaticResource BgRaisedBrush}"
                                BorderBrush="{StaticResource AccentBlueBrush}"
                                BorderThickness="3,0,0,0"
                                Padding="16,12" Margin="0,0,0,16">
                            <TextBlock
                                Text="&quot;It monitors your prints. It goes Bing. Never leave a print behind again. But No ONE expects a Notification App, quietly waiting, to suddenly pop up and notify you, in the middle of your latest doom scrolling, or whatever it is you're doing alone, in front of the computer late at night, and I'm not judging, of the fact that the latest 8 hour print went from perfection to Spag bol (Minus the bol) in 2.3 nano seconds flat.&quot;"
                                FontFamily="Segoe UI Variable, Segoe UI"
                                FontSize="12"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontStyle="Italic"
                                TextWrapping="Wrap" LineHeight="20"/>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Source code" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="MIT licence. The community may do as they wish." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="GitHub ↗"
                                                Style="{StaticResource GhostButton}"
                                                VerticalAlignment="Center"
                                                Click="OnGitHubClick"/>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRow}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="The full origin story" Style="{StaticResource SettingLabel}"/>
                                            <TextBlock Text="As filed with the Redundant Department of Redundancy." Style="{StaticResource SettingSubLabel}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Read ↗"
                                                Style="{StaticResource GhostButton}"
                                                VerticalAlignment="Center"
                                                Click="OnOriginStoryClick"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock
                            Text="Inspired by Monty Python's &quot;The Machine That Goes Ping&quot;. No NHS budget was harmed in the making of this app, although the Redundant Department of Redundancy was notified, twice, in triplicate."
                            FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                            Foreground="{StaticResource TextDimBrush}"
                            FontStyle="Italic" TextWrapping="Wrap"
                            HorizontalAlignment="Center" TextAlignment="Center"
                            Margin="20,10,20,4"/>
                        <TextBlock Text="Philosophically indebted to Sir Terry Pratchett."
                                   FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"
                                   FontStyle="Italic" HorizontalAlignment="Center"
                                   Margin="0,2,0,20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Footer ────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgDeepestBrush}"
                BorderBrush="{StaticResource BorderBlueBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText"
                           Grid.Column="0"
                           Text="Not connected — enter credentials above"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           FontSize="12"
                           Foreground="{StaticResource TextDimBrush}"
                           FontStyle="Italic"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Save"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Click="OnSaveClick"/>
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Style="{StaticResource GhostButton}"
                            IsEnabled="False"
                            Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>