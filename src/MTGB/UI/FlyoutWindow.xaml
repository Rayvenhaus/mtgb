<Window x:Class="MTGB.UI.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MTGB"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        UseLayoutRounding="True">

    <Window.Resources>

        <!-- ── Colours ──────────────────────────────────────── -->
        <Color x:Key="BgDeep">#0D0D0F</Color>
        <Color x:Key="BgRaised">#141417</Color>
        <Color x:Key="BgCard">#1A1A1F</Color>
        <Color x:Key="BgHover">#22222A</Color>
        <Color x:Key="Brass">#C9930E</Color>
        <Color x:Key="BrassDim">#8B6508</Color>
        <Color x:Key="GoldText">#F0C840</Color>
        <Color x:Key="TextPrimary">#F0EDE8</Color>
        <Color x:Key="TextSecondary">#9A9080</Color>
        <Color x:Key="TextDim">#5A5248</Color>
        <Color x:Key="StatusGreen">#3BB273</Color>
        <Color x:Key="StatusAmber">#F18F01</Color>
        <Color x:Key="StatusRed">#E84855</Color>
        <Color x:Key="BorderBrass">#38C9930E</Color>

        <SolidColorBrush x:Key="BgDeepBrush"
                         Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="BgRaisedBrush"
                         Color="{StaticResource BgRaised}"/>
        <SolidColorBrush x:Key="BgCardBrush"
                         Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BgHoverBrush"
                         Color="{StaticResource BgHover}"/>
        <SolidColorBrush x:Key="BrassBrush"
                         Color="{StaticResource Brass}"/>
        <SolidColorBrush x:Key="BrassDimBrush"
                         Color="{StaticResource BrassDim}"/>
        <SolidColorBrush x:Key="GoldTextBrush"
                         Color="{StaticResource GoldText}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"
                         Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"
                         Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextDimBrush"
                         Color="{StaticResource TextDim}"/>
        <SolidColorBrush x:Key="StatusGreenBrush"
                         Color="{StaticResource StatusGreen}"/>
        <SolidColorBrush x:Key="StatusAmberBrush"
                         Color="{StaticResource StatusAmber}"/>
        <SolidColorBrush x:Key="StatusRedBrush"
                         Color="{StaticResource StatusRed}"/>
        <SolidColorBrush x:Key="BorderBrassBrush"
                         Color="{StaticResource BorderBrass}"/>

        <!-- ── Printer card style ────────────────────────────── -->
        <Style x:Key="PrinterCard" TargetType="Border">
            <Setter Property="Background"
                    Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource BorderBrassBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="6"/>
            <Setter Property="Padding"
                    Value="10"/>
            <Setter Property="Margin"
                    Value="0 0 0 5"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
        </Style>

        <!-- ── Action button style ───────────────────────────── -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource BgCardBrush}"/>
            <Setter Property="Foreground"
                    Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource BorderBrassBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize"
                    Value="11"/>
            <Setter Property="Padding"
                    Value="0 7"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource GoldTextBrush}"/>
                                <Setter Property="BorderBrush"
                                        Value="{StaticResource BrassBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource BgDeepBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle button style ───────────────────────────── -->
        <Style x:Key="MuteToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Width="36" Height="20"
                                    CornerRadius="10"
                                    Background="{StaticResource StatusGreenBrush}"/>
                            <Ellipse x:Name="Thumb"
                                     Width="16" Height="16"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     Margin="2 0 0 0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform
                                        x:Name="ThumbTranslate"
                                        X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track"
                                        Property="Background"
                                        Value="{StaticResource TextDimBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ThumbTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="16"
                                                Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ThumbTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="0"
                                                Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ── Slide animation ───────────────────────────────────── -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        Storyboard.TargetName="MainBorder"
                        Storyboard.TargetProperty="Opacity"
                        From="0" To="1"
                        Duration="0:0:0.18"/>
                    <DoubleAnimation
                        Storyboard.TargetName="SlideTransform"
                        Storyboard.TargetProperty="Y"
                        From="20" To="0"
                        Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- ── Root border — Art Deco dark brass ─────────────────── -->
    <Border x:Name="MainBorder"
            Background="{StaticResource BgRaisedBrush}"
            BorderBrush="{StaticResource BrassBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Opacity="0">

        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="20"/>
        </Border.RenderTransform>

        <StackPanel>

            <!-- ── Header ────────────────────────────────────── -->
            <Border Background="{StaticResource BgDeepBrush}"
                    CornerRadius="14 14 0 0"
                    Padding="14 12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bing indicator dot -->
                    <Ellipse Grid.Column="0"
                             x:Name="BingDot"
                             Width="10" Height="10"
                             Fill="{StaticResource StatusGreenBrush}"
                             Margin="0 0 10 0"
                             VerticalAlignment="Center"/>

                    <!-- Title -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="M · T · G · B"
                                   FontFamily="Georgia"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GoldTextBrush}"/>
                        <TextBlock x:Name="HeaderSubtitle"
                                   Text="IT GOES BING"
                                   FontFamily="Courier New"
                                   FontSize="9"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </StackPanel>

                    <!-- Mute toggle -->
                    <ToggleButton Grid.Column="2"
                                  x:Name="MuteToggle"
                                  Style="{StaticResource MuteToggle}"
                                  ToolTip="Mute all notifications"
                                  Click="OnMuteToggleClick"/>
                </Grid>
            </Border>

            <!-- ── Header / body divider ─────────────────────── -->
            <Border Height="1"
                    Background="{StaticResource BorderBrassBrush}"/>

            <!-- ── Printer cards ──────────────────────────────── -->
            <StackPanel x:Name="PrinterCardsPanel"
                        Margin="8 8 8 4"/>

            <!-- ── No printers message ───────────────────────── -->
            <Border x:Name="NoPrintersPanel"
                    Visibility="Collapsed"
                    Padding="14 20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="No printers found."
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="The Ministry is investigating."
                               FontFamily="Courier New"
                               FontSize="10"
                               Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>
            </Border>

            <!-- ── Divider ────────────────────────────────────── -->
            <Border Height="1"
                    Background="{StaticResource BorderBrassBrush}"
                    Margin="8 0"/>

            <!-- ── Action buttons ─────────────────────────────── -->
            <Grid Margin="8 6 8 6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="History"
                        Style="{StaticResource ActionButton}"
                        Click="OnHistoryClick"/>

                <Button Grid.Column="2"
                        Content="Settings"
                        Style="{StaticResource ActionButton}"
                        Foreground="{StaticResource BrassBrush}"
                        Click="OnSettingsClick"/>

                <Button Grid.Column="4"
                        Content="Dashboard ↗"
                        Style="{StaticResource ActionButton}"
                        Click="OnDashboardClick"/>

                <Button Grid.Column="6"
                        Content="Exit"
                        Style="{StaticResource ActionButton}"
                        Foreground="{StaticResource StatusRedBrush}"
                        Click="OnExitClick"/>
            </Grid>

            <!-- ── Footer ────────────────────────────────────── -->
            <Border Background="{StaticResource BgDeepBrush}"
                    CornerRadius="0 0 14 14"
                    Padding="12 8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="LastPolledText"
                               Text="Initialising..."
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="{StaticResource TextDimBrush}"
                               FontStyle="Italic"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               x:Name="WebhookStatusText"
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="{StaticResource BrassDimBrush}"
                               VerticalAlignment="Center"
                               Cursor="Hand"/>
                </Grid>
            </Border>

        </StackPanel>
    </Border>
</Window>
