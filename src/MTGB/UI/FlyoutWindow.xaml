<Window x:Class="MTGB.UI.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MTGB"
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/mtgbTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Printer card ───────────────────────────────── -->
            <Style x:Key="PrinterCard" TargetType="Border">
                <Setter Property="Background"
                        Value="{StaticResource BgRaisedBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BorderBlueBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="Padding"         Value="12"/>
                <Setter Property="Margin"          Value="0,0,0,6"/>
                <Setter Property="Cursor"          Value="Hand"/>
            </Style>

            <!-- ── Action button ──────────────────────────────── -->
            <Style x:Key="ActionButton" TargetType="Button">
                <Setter Property="Background"
                        Value="{StaticResource BgRaisedBrush}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource TextMutedBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{StaticResource BorderBlueBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily"
                        Value="Segoe UI Variable, Segoe UI"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding"    Value="0,8"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Outer"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Outer"
                                            Property="Background"
                                            Value="{StaticResource BgDeepestBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource GoldPrimaryBrush}"/>
                                    <Setter TargetName="Outer"
                                            Property="BorderBrush"
                                            Value="{StaticResource AccentBlueBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Outer"
                                            Property="Background"
                                            Value="{StaticResource BgDeepestBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Mute toggle ────────────────────────────────── -->
            <Style x:Key="MuteToggle" TargetType="ToggleButton">
                <Setter Property="Width"  Value="36"/>
                <Setter Property="Height" Value="20"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="Track"
                                        Width="36" Height="20"
                                        CornerRadius="10"
                                        Background="{StaticResource TextDimBrush}"/>
                                <Ellipse x:Name="Thumb"
                                         Width="16" Height="16"
                                         Fill="{StaticResource TextPrimaryBrush}"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform
                                            x:Name="ThumbTranslate" X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track"
                                            Property="Background"
                                            Value="{StaticResource SemanticWarningBrush}"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="ThumbTranslate"
                                                    Storyboard.TargetProperty="X"
                                                    To="16" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="ThumbTranslate"
                                                    Storyboard.TargetProperty="X"
                                                    To="0" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- ── Slide animation ───────────────────────────────────── -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        Storyboard.TargetName="MainBorder"
                        Storyboard.TargetProperty="Opacity"
                        From="0" To="1" Duration="0:0:0.18"/>
                    <DoubleAnimation
                        Storyboard.TargetName="SlideTransform"
                        Storyboard.TargetProperty="Y"
                        From="20" To="0" Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- ── Root border ───────────────────────────────────────── -->
    <Border x:Name="MainBorder"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource AccentBlueBrush}"
            BorderThickness="2"
            CornerRadius="14"
            Opacity="0">

        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="20"/>
        </Border.RenderTransform>

        <StackPanel>

            <!-- ── Header ────────────────────────────────────── -->
            <Border Background="{StaticResource BgDeepestBrush}"
                    CornerRadius="14,14,0,0"
                    Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0"
                             x:Name="BingDot"
                             Width="10" Height="10"
                             Fill="{StaticResource SemanticSuccessBrush}"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="MTGB — The Monitor That Goes Bing"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource GoldPrimaryBrush}"/>
                    </StackPanel>

                    <ToggleButton Grid.Column="2"
                                  x:Name="MuteToggle"
                                  Style="{StaticResource MuteToggle}"
                                  ToolTip="Mute all notifications"
                                  Click="OnMuteToggleClick"/>
                </Grid>
            </Border>

            <!-- ── Divider ────────────────────────────────────── -->
            <Border Height="1" Background="{StaticResource BorderBlueBrush}"/>

            <!-- ── Muted banner ───────────────────────────────── -->
            <Border x:Name="MutedBanner"
                    Background="#20F18F01"
                    BorderBrush="#59F18F01"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed"
                    Padding="12,7">
                <TextBlock Text="NOTIFICATIONS MUTED · BLESSED SILENCE."
                           FontFamily="Segoe UI Variable, Segoe UI"
                           FontSize="11" FontStyle="Italic" FontWeight="SemiBold"
                           Foreground="{StaticResource SemanticWarningBrush}"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- ── Printer cards ──────────────────────────────── -->
            <StackPanel x:Name="PrinterCardsPanel" Margin="10,10,10,4"/>

            <!-- ── No printers message ───────────────────────── -->
            <Border x:Name="NoPrintersPanel"
                    Visibility="Collapsed"
                    Padding="14,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="No printers found."
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="The Ministry is investigating."
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TextDimBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Divider ────────────────────────────────────── -->
            <Border Height="1"
                    Background="{StaticResource BorderBlueBrush}"
                    Margin="10,0"/>

            <!-- ── Action buttons ─────────────────────────────── -->
            <Grid Margin="10,8,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="History"
                        Style="{StaticResource ActionButton}"
                        Click="OnHistoryClick"/>

                <Button Grid.Column="2"
                        Content="Settings"
                        Style="{StaticResource ActionButton}"
                        Foreground="{StaticResource AccentBlueBrush}"
                        Click="OnSettingsClick"/>

                <Button Grid.Column="4"
                        Content="Dashboard ↗"
                        Style="{StaticResource ActionButton}"
                        Click="OnDashboardClick"/>

                <Button Grid.Column="6"
                        Content="Exit"
                        Style="{StaticResource ActionButton}"
                        Foreground="{StaticResource SemanticErrorBrush}"
                        Click="OnExitClick"/>
            </Grid>

            <!-- ── Footer ────────────────────────────────────── -->
            <Border Background="{StaticResource BgDeepestBrush}"
                    CornerRadius="0,0,14,14"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="LastPolledText"
                               Text="Initialising..."
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10" FontStyle="Italic"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               x:Name="WebhookStatusText"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10"
                               Foreground="{StaticResource AccentBlueBrush}"
                               VerticalAlignment="Center"
                               Cursor="Hand"/>
                </Grid>
            </Border>

        </StackPanel>
    </Border>
</Window>